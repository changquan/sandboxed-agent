{
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-spec-on-commit.sh",
            "if": "Bash(git commit*)",
            "shell": "bash",
            "statusMessage": "Checking spec is up to date..."
          }
        ]
      }
    ]
  }
}
